# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: Required for Google Sign-In.
# Configure the OAuth redirect URI in Google Cloud as:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# SUPABASE_URL: The URL of your Supabase project (e.g. https://abcde.supabase.co)
# If provided, the backend will automatically and instantly switch from local JSON fallback to your real live Supabase PostgreSQL database!
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: The public/anonymous API key of your Supabase project.
SUPABASE_ANON_KEY="your-supabase-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Server-only key used by npm run content:sync.
# Never expose this to the frontend or commit a real value.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# SMTP settings for welcome emails on registration.
# Leave these unset to skip email delivery gracefully.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="no-reply@skillbridge.app"
