# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyB5jEbJyIfK95JNRXH6E20GS5IppxKKqgc"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project (e.g. https://abcde.supabase.co)
# If provided, the backend will automatically and instantly switch from local JSON fallback to your real live Supabase PostgreSQL database!
SUPABASE_URL="https://vggmhsikzqwavodiiyrb.supabase.co"

# SUPABASE_ANON_KEY: The public/anonymous API key of your Supabase project.
SUPABASE_ANON_KEY="sb_publishable_3Ml0pLMfoRxDLJNQ1C_j5w_C5C2w-ar"
